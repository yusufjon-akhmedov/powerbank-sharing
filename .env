# PostgreSQL
POSTGRES_USER=powerbank
POSTGRES_PASSWORD=powerbank_secret

# Per-database credentials (reuse same user for simplicity; override per-service as needed)
USERS_DB=users_db
STATIONS_DB=stations_db
RENTALS_DB=rentals_db
PAYMENTS_DB=payments_db
KEYCLOAK_DB=keycloak_db

# Kafka
KAFKA_BROKER=kafka:9092

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret
KEYCLOAK_DB_USER=powerbank
KEYCLOAK_DB_PASSWORD=powerbank_secret

# Kong (DB-less, no DB credentials needed)
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001
