<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001" author="powerbank">
        <createTable tableName="cards">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="card_number" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="holder_name" type="VARCHAR(100)"/>
            <column name="balance" type="NUMERIC(19,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(3)" defaultValue="UZS"/>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ"/>
            <column name="updated_at" type="TIMESTAMPTZ"/>
        </createTable>

        <!-- Prevents duplicate card registrations per user -->
        <createIndex tableName="cards" indexName="idx_cards_user_card_number" unique="true">
            <column name="user_id"/>
            <column name="card_number"/>
        </createIndex>

        <!-- For loading all cards belonging to a user -->
        <createIndex tableName="cards" indexName="idx_cards_user_id">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
